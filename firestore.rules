rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /encrypted_vault_snapshots/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /shared_credentials/{docId} {
      allow read: if request.auth != null && (
        resource.data.recipientUserId == request.auth.uid ||
        resource.data.senderUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.senderUserId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.recipientUserId == request.auth.uid;
    }
    match /public_keys/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /device_trust/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
