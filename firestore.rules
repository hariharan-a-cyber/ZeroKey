rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function smallString(s) {
      return s is string && s.size() < 200000;
    }

    function reasonableTime(t) {
      return t is int && t > 0 && t < (request.time.toMillis() + 7 * 24 * 60 * 60 * 1000);
    }

    // Encrypted vault snapshots — only the owner can read/write.
    match /encrypted_vault_snapshots/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Emergency Access Configuration — readable ONLY by the owner or the named
    // trusted contact. (Previously: any signed-in user could read any config,
    // leaking trusted contacts' UIDs and emails for every ZeroKey user.)
    match /emergency_access_config/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        request.auth.uid == resource.data.trustedContactUid
      );
      allow write: if isOwner(userId);
    }

    // Emergency Access Requests — strict scoping.
    //
    // SECURITY: the previous wide-open rules let any signed-in user update any
    // request's status. A trusted contact could create a request and immediately
    // flip status=GRANTED + approveAt=0 via the Firebase REST API, bypassing the
    // 48-hour safety window and claiming the vault key. These tightened rules
    // restrict status/approveAt changes to the OWNER only.
    match /emergency_access_requests/{requestId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.ownerUid ||
        request.auth.uid == resource.data.requesterUid
      );
      allow create: if signedIn()
                    && request.resource.data.requesterUid == request.auth.uid
                    && request.resource.data.status == "PENDING";
      allow update: if signedIn()
                    && request.auth.uid == resource.data.ownerUid
                    && request.resource.data.diff(resource.data)
                          .affectedKeys().hasOnly(["status", "approveAt"]);
      allow delete: if false;
    }

    // Device-trust records (one doc per device per user).
    match /users/{userId}/devices/{deviceId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        !(resource.data.revoked == true && request.resource.data.trusted == true);
      allow delete: if isOwner(userId);
    }

    // Public key registry for end-to-end sharing.
    match /public_keys/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId) &&
                   smallString(request.resource.data.publicKey) &&
                   request.resource.data.userId == userId;
    }

    // Encrypted credential shares.
    match /shared_credentials/{docId} {
      allow read: if signedIn() && (
        resource.data.recipientUserId == request.auth.uid ||
        resource.data.senderUserId == request.auth.uid
      );
      allow create: if signedIn()
                    && request.resource.data.senderUserId == request.auth.uid
                    && request.resource.data.recipientUserId != request.auth.uid
                    && smallString(request.resource.data.encryptedPayload)
                    && reasonableTime(request.resource.data.expiresAt);
      allow delete: if signedIn() && resource.data.recipientUserId == request.auth.uid;
      allow update: if false;
    }

    // Recovery blob metadata (already protected by client-side trial decryption,
    // but only the owner can write to their own doc).
    match /users/{userId}/recovery/{docId} {
      allow read, write: if isOwner(userId);
    }
  }
}